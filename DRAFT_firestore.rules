rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.auth.uid == userId && (
        incoming().role == 'USUARIO' // Default role for new users
      );
      allow update: if isSignedIn() && request.auth.uid == userId && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'lastLogin'])
      );
    }

    // 2. Assets
    match /assets/{assetId} {
      function isAdmin() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMINISTRADOR', 'GESTOR'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'responsible']) && isEmailVerified())
      );
      allow delete: if false; // Imobilizado não se deleta, se baixa (update status)
    }

    // 3. Movements
    match /movements/{movementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        incoming().requesterId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMINISTRADOR', 'GESTOR']
      );
    }
  }
}
